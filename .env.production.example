# Copy to .env.production and fill in real values, then:
#   docker compose up -d --build
# .env.production is gitignored — never commit it.

# SQLite database on the mounted /data volume (do not change for Docker).
DATABASE_URL=file:/data/prod.db

# Session signing secret — generate with: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Admin account, created on first boot (change the password!)
ADMIN_EMAIL=admin@yourbrand.com
ADMIN_PASSWORD=change-me-to-something-strong

# Store config — seeds the Settings on first boot; editable later in /admin/settings.
NEXT_PUBLIC_STORE_NAME=The Style Syndicate
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=919876543210
NEXT_PUBLIC_UPI_ID=yourbrand@okhdfcbank
NEXT_PUBLIC_SUPPORT_EMAIL=orders@yourbrand.com
