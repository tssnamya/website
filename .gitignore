# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all real env files, keep the templates
.env*
!.env.example
!.env.production.example

# prisma — local SQLite dev database (migrations ARE committed)
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-wal
/prisma/*.db-shm

# locally uploaded product images (keep the folder, ignore contents)
/public/uploads/*
!/public/uploads/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# turbopack / build caches
.turbo/

# editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# logs
*.log
logs/

# secrets / certificates (extra safety)
*.key
*.cert
*.p12
secrets.*
