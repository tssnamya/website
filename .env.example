# ---------------------------------------------------------------------------
# The Style Syndicate — environment template. Copy to `.env` and fill values.
# ---------------------------------------------------------------------------

# PostgreSQL. Local dev: `docker compose up -d db` then use the URL below.
# Prod (Neon/Vercel): DATABASE_URL = pooled endpoint, DIRECT_URL = direct endpoint.
DATABASE_URL="postgresql://tss:tsspass@localhost:5433/tss?schema=public"
DIRECT_URL="postgresql://tss:tsspass@localhost:5433/tss?schema=public"

# Session signing secret — generate with: openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Seeded admin account
ADMIN_EMAIL="admin@yourbrand.com"
ADMIN_PASSWORD="change-me"

# Public store config (exposed to the browser)
NEXT_PUBLIC_STORE_NAME="The Style Syndicate"
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER="919876543210"
NEXT_PUBLIC_UPI_ID="yourbrand@okhdfcbank"
NEXT_PUBLIC_SUPPORT_EMAIL="orders@yourbrand.com"

# Cloudinary — REQUIRED on Vercel/serverless (ephemeral disk). Optional locally.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
